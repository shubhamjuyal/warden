# Warden configuration. Copy to .env and fill in.
#
# these tokens live in DIFFERENT places, docker-compose hands each one only to the container that should have it.

# ── Permission ledger ───────────────────────────────────────────────────────
# Used by the Python services (note the +psycopg scheme). Compose overrides this
# to point at the `postgres` service; set it only for running things locally.
DATABASE_URL=postgresql+psycopg://warden:warden@localhost:5432/warden

# ── Sandboxed agent: READ-ONLY GitHub + the model + Slack ───────────────────
# A fine-grained PAT (or GitHub App token) with ONLY read access: Issues:Read,
# Metadata:Read. If this leaks, the worst case is information disclosure — it
# cannot label, assign, or close anything.
GITHUB_READ_TOKEN=github_pat_readonly_xxx

OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o

# Slack app in Socket Mode (no public URL needed):
#   - bot token  (xoxb-…) : scopes app_mentions:read, chat:write
#   - app token  (xapp-…) : connection:write  (Socket Mode)
SLACK_BOT_TOKEN=xoxb-xxx
SLACK_APP_TOKEN=xapp-xxx

# ── Permissioned runner: the ONLY write-scoped credential ───────────────────
# A separate token with write access: Issues:Write. This is given ONLY to the
# runner container. Never put it in the agent's environment — the agent will
# refuse to start if it sees it.
GITHUB_WRITE_TOKEN=github_pat_write_xxx
